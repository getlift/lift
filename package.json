  "types": "dist/src/plugin.d.ts",
  "peerDependencies": {
    "osls": "^3 || ^4.0.0-beta.0",
    "serverless": "^3 || ^4"
  },
  "peerDependenciesMeta": {
    "osls": {
      "optional": true
    },
    "serverless": {
      "optional": true
    }
  }
